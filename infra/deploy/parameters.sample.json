{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "org": { "value": "<your-org>" },
    "env": { "value": "dev" },
    "location": { "value": "<azure-region>" },
    "loc": { "value": "<caf-region-abbrev>" },
    "uniqueSuffix": { "value": "<unique-3-to-12-chars>" },

    "adminUsername": { "value": "azureadmin" },
    "adminSshPublicKey": { "value": "<ssh-public-key>" },
    "adminPassword": { "value": "<secure-password-min-16-chars>" },

    "linuxImageVersion": { "value": "<gallery-version-e.g.-2025.9.5>" },
    "windowsImageVersion": { "value": "<gallery-version-e.g.-2025.9.5>" },

    "linuxVmSize": { "value": "Standard_D4s_v5" },
    "windowsVmSize": { "value": "Standard_D4s_v5" },
    "enableGhPublicIp": { "value": false },
    "confirmUseGallery": { "value": true }
  }
}
